{
  "id": null,
  "uid": "fintrack-main",
  "title": "FinTrack - Operations Dashboard",
  "description": "Live metrics for the FinTrack expense tracker",
  "tags": ["fintrack", "flask", "production"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/sec)",
      "description": "Requests per second across all routes, grouped by HTTP method. Uses flask_http_request_duration_seconds_count — the real metric name from prometheus_flask_exporter.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_duration_seconds_count[5m])) by (method)",
          "legendFormat": "{{ method }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 2,
      "title": "HTTP Error Rate (%)",
      "description": "Percentage of 5xx responses over total requests. Shows 0% when there is no traffic (division-by-zero guarded with 'or vector(0)').",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(flask_http_request_duration_seconds_count{status=~\"5..\"}[5m])) / sum(rate(flask_http_request_duration_seconds_count[5m])) or vector(0)",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      }
    },

    {
      "id": 3,
      "title": "Response Latency — p50 / p95 / p99",
      "description": "Percentile latencies from the flask_http_request_duration_seconds histogram. The 'le' label is included in the by() clause to ensure correct quantile calculation across multiple pods.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      }
    },

    {
      "id": 4,
      "title": "DB Query Duration (p95)",
      "description": "95th percentile of the custom fintrack_db_query_duration_seconds histogram. The 'le' label is included in by() for correct multi-pod aggregation.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(fintrack_db_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 DB latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.5, "color": "red" }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      }
    },

    {
      "id": 5,
      "title": "Expenses Created (by category)",
      "description": "Cumulative value of fintrack_expenses_created_total counter, labelled by category. The line rises each time an expense is added in that category.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "fintrack_expenses_created_total",
          "legendFormat": "{{ category }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      }
    },

    {
      "id": 6,
      "title": "Login Events",
      "description": "Successful vs failed logins per 5-minute window using increase(). Unit is 'none' to avoid decimal fractions on whole-number event counts.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "increase(fintrack_login_success_total[5m])",
          "legendFormat": "Successful (per 5m)",
          "refId": "A"
        },
        {
          "expr": "increase(fintrack_login_failure_total[5m])",
          "legendFormat": "Failed (per 5m)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      }
    },

    {
      "id": 7,
      "title": "Registered Users",
      "description": "Current value of fintrack_registered_users_total gauge. max() aggregates across pods so two pods emitting the same count don't show duplicates.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "max(fintrack_registered_users_total)",
          "legendFormat": "Users",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "blue" }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },

    {
      "id": 8,
      "title": "Total Expenses Created",
      "description": "Total expenses across all categories. sum(max(...) by (category)) takes the max per category across pods to avoid double-counting, then sums all categories into one number.",
      "type": "stat",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(max(fintrack_expenses_created_total) by (category))",
          "legendFormat": "Total",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },

    {
      "id": 9,
      "title": "CSV Exports",
      "description": "Total CSV downloads. max() across pods prevents double-counting when multiple pods are running.",
      "type": "stat",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "max(fintrack_csv_exports_total)",
          "legendFormat": "Exports",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "purple" }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },

    {
      "id": 10,
      "title": "App Uptime",
      "description": "min(up{job='fintrack'}) — if ANY pod is down this shows 0/DOWN. Returns 1/UP only when all pods are healthy.",
      "type": "stat",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "min(up{job=\"fintrack\"})",
          "legendFormat": "Status",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN" },
                "1": { "text": "UP" }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    }
  ],
  "schemaVersion": 38,
  "version": 3
}
